<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <!-- 헤더 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="위젯 스타일"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="20dp" />

        <!-- 미리보기 영역 -->
        <FrameLayout
            android:id="@+id/preview_container"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/widget_config_preview_bg">

            <LinearLayout
                android:id="@+id/preview_widget"
                android:layout_width="180dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@drawable/widget_background"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/preview_text1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3월"
                    android:textSize="12sp"
                    android:textColor="#666666" />

                <TextView
                    android:id="@+id/preview_text2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/preview_text3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="일요일"
                    android:textSize="12sp"
                    android:textColor="#666666" />

            </LinearLayout>

        </FrameLayout>

        <!-- 배경색 섹션 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_config_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="배경"
                android:textSize="13sp"
                android:textColor="#8E8E93"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- 라이트 -->
                <LinearLayout
                    android:id="@+id/option_light"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp">

                        <View
                            android:id="@+id/color_white"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:background="@drawable/widget_color_circle_white" />

                        <View
                            android:id="@+id/border_white"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:background="@drawable/widget_color_selected"
                            android:visibility="visible" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="라이트"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />

                </LinearLayout>

                <!-- 다크 -->
                <LinearLayout
                    android:id="@+id/option_dark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp">

                        <View
                            android:id="@+id/color_black"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:background="@drawable/widget_color_circle_black" />

                        <View
                            android:id="@+id/border_black"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:background="@drawable/widget_color_selected"
                            android:visibility="gone" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="다크"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 투명도 섹션 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_config_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="배경 투명도"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tv_opacity_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="16sp"
                    android:textColor="#023c69"
                    android:textStyle="bold" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_opacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100"
                android:progressTint="#023c69"
                android:thumbTint="#023c69" />

        </LinearLayout>

        <!-- 적용 버튼 -->
        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="적용하기"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/widget_config_button_bg"
            android:stateListAnimator="@null" />

    </LinearLayout>

</ScrollView>
